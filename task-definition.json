{
  "family": "discodeit-task",
  "containerDefinitions": [
    {
      "name": "discodeit-app",
      "image": "public.ecr.aws/c8t8h4t0/discodeit:latest",
      "cpu": 256,
      "memory": 512,
      "memoryReservation": 256,
      "portMappings": [
        {
          "name": "discodeit-app-80-tcp",
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "JAVA_TOOL_OPTIONS",
          "value": "-Xmx512m -Xms256m -XX:MaxMetaspaceSize=64m -XX:+UseSerialGC"
        }
      ],
      "environmentFiles": [
        {
          "value": "arn:aws:s3:::discodeit-binary-content-storage-pje/discodeit.env",
          "type": "s3"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/discodeit-task",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::334935450617:role/ecsTaskExecutionRole",
  "networkMode": "bridge",
  "requiresCompatibilities": [
    "EC2"
  ],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}